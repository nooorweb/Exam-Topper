-- ─────────────────────────────────────────────────────────────
-- 5. Mathematics MCQs  →  mathematics_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.mathematics_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b3m30001-1111-4a1b-82c3-d4e5f6a7b8c9',
   'By selling an article for Rs. 240, a shopkeeper loses 20%. To make a profit of 20%, at what price should he sell it?',
   '',
   2,
   'Step-by-step solution: \n1. Let Cost Price (CP) be x.\n2. Since there is a 20% loss, Selling Price (SP) = 80% of CP. So, 0.8x = 240 => x = 240 / 0.8 = Rs. 300.\n3. To make a 20% profit, the new SP must be 120% of CP.\n4. New SP = 300 * 1.2 = Rs. 360.',
   'Percentages', 'KPPSC Tehsildar 2023', 'high', true, 9, 'high', true),

  ('b3m30002-2222-4b2c-83d4-e5f6a7b8c9d0',
   'The average age of 5 students is 20 years. If one student is excluded, the new average age of the remaining 4 students becomes 22 years. What is the age of the excluded student?',
   '["10 years","12 years","14 years","16 years"]',
   1,
   'Step-by-step solution: \n1. Total age of 5 students = 5 * 20 = 100 years.\n2. When 1 student is excluded, remaining students = 4, and their new average = 22.\n3. Total age of the 4 remaining students = 4 * 22 = 88 years.\n4. Age of the excluded student = 100 - 88 = 12 years.',
   'Averages', 'FPSC Inspector 2024', 'high', true, 7, 'high', true),

  ('b3m30003-3333-4c3d-84e5-f6a7b8c9d0e1',
   'A train 100 meters long completely passes a stationary telephone pole in exactly 10 seconds. What is the speed of the train in meters per second?',
   '["5 m/s","10 m/s","15 m/s","20 m/s"]',
   1,
   'Step-by-step solution: \n1. To cross a stationary pole, the train must cover a distance equal to its own length.\n2. Distance = 100 meters, Time = 10 seconds.\n3. Speed = Distance / Time = 100 / 10 = 10 m/s.',
   'Speed & Distance', 'FIA Sub-Inspector 2022', 'medium', true, 5, 'medium', true),

  ('b3m30004-4444-4d4e-85f6-a7b8c9d0e1f2',
   'Solve the linear algebraic equation for x: 2x + 5 = 15.',
   '["3","4","5","6"]',
   2,
   'Step-by-step solution: \n1. Given: 2x + 5 = 15.\n2. Subtract 5 from both sides: 2x = 15 - 5 => 2x = 10.\n3. Divide by 2: x = 10 / 2 = 5.',
   'Algebra', 'ETEA Police Constable 2024', 'medium', true, 4, 'medium', true),

  ('b3m30005-5555-4e5f-86a7-b8c9d0e1f2a3',
   'What is the area of a perfect circle whose total circumference is measured at exactly 44 cm? (Assume pi = 22/7)',
   '["144 cm²","154 cm²","164 cm²","174 cm²"]',
   1,
   'Step-by-step solution: \n1. Circumference = 2 * pi * r = 44.\n2. 2 * (22/7) * r = 44 => (44/7) * r = 44 => r = 7 cm.\n3. Area of a circle = pi * r² = (22/7) * 7 * 7 = 22 * 7 = 154 cm².',
   'Geometry', 'ETEA Junior Clerk 2024', 'medium', true, 6, 'medium', true),

  ('b3m30006-6666-4f6a-87b8-c9d0e1f2a3b4',
   'Calculate the Highest Common Factor (HCF) of the numbers 12, 15, and 21.',
   '["2","3","4","5"]',
   1,
   'Step-by-step solution: \n1. Prime factors of 12 = 2² * 3.\n2. Prime factors of 15 = 3 * 5.\n3. Prime factors of 21 = 3 * 7.\n4. The highest common prime factor is 3. Therefore, HCF = 3.',
   'Number System', 'KPPSC Assistant Sub-Inspector 2023', 'medium', true, 6, 'high', true),

  ('b3m30007-7777-4a7b-88c9-d0e1f2a3b4c5',
   'Worker A can finish a project alone in 10 days, and Worker B can complete the same project in 15 days. If they work together, how many days will it take them to finish the project?',
   '["5 days","6 days","7 days","8 days"]',
   1,
   'Step-by-step solution: \n1. Work rate of A = 1/10 per day.\n2. Work rate of B = 1/15 per day.\n3. Combined rate = 1/10 + 1/15 = 3/30 + 2/30 = 5/30 = 1/6.\n4. Together they will complete the project in 6 days.',
   'Time & Work', 'KPPSC PMS 2021', 'high', true, 10, 'high', true),

  ('b3m30008-8888-4b8c-89d0-e1f2a3b4c5d6',
   'Two numbers are in the ratio of 3:4. If the sum of these two numbers is 70, find the value of the larger number.',
   '["30","40","50","60"]',
   1,
   'Step-by-step solution: \n1. Let the two numbers be 3x and 4x.\n2. Their sum = 3x + 4x = 7x = 70 => x = 10.\n3. The larger number is 4x = 4 * 10 = 40.',
   'Ratios & Proportions', 'FIA Sub-Inspector 2022', 'medium', true, 6, 'high', true),

  ('b3m30009-9999-4c9d-8012-f2a3b4c5d6e7',
   'Which ancient Greek mathematician is historically celebrated as the ''Father of Geometry''?',
   '["Pythagoras","Euclid","Archimedes","Aristotle"]',
   1,
   'Euclid of Alexandria is universally recognized as the Father of Geometry due to his groundbreaking compilation ''Elements'', which structured geometric axioms.[10]',
   'Geometry', 'CSS General Ability 2023', 'medium', true, 5, 'medium', true),

  ('b3m30010-aaaa-4d0e-81f2-a3b4c5d6e7f8',
   'In the BASIC programming language and standard mathematics, the LOG function refers to a natural logarithm. What is its base?',
   '',
   2,
   'The LOG function in basic algebraic calculators and early programming languages like BASIC stands for the natural logarithm, which uses the mathematical constant ''e'' (approx. 2.71828) as its base.[10]',
   'Number System', 'KPPSC Tehsildar 2023', 'high', true, 3, 'medium', true)

