-- 3. General Knowledge MCQs  →  general_knowledge_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.general_knowledge_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b3g30001-1111-4a1b-82c3-d4e5f6a7b8c9',
   'The international headquarters of Transparency International, the anti-corruption watchdog, is situated in which city?',
   '',
   2,
   'Transparency International is a prominent global non-governmental organization headquartered in Berlin, Germany.',
   'International Orgs', 'FPSC ASI 2023', 'high', true, 5, 'high', true),

  ('b3g30002-2222-4b2c-83d4-e5f6a7b8c9d0',
   'What is the capital city of Canada?',
   '',
   2,
   'Ottawa is the official capital city of Canada, located in the province of Ontario. It is a highly repeated past paper question.',
   'Capitals & Countries', 'NTS Clerk 2023', 'medium', true, 8, 'high', true),

  ('b3g30003-3333-4c3d-84e5-f6a7b8c9d0e1',
   'Which planet in our solar system is commonly designated as the ''Red Planet''?',
   '',
   1,
   'Mars is known as the Red Planet due to the large amount of iron oxide (rust) on its surface, which gives it a reddish appearance.[7]',
   'Science & Technology', 'ETEA Police Constable 2024', 'medium', true, 6, 'medium', true),

  ('b3g30004-4444-4d4e-85f6-a7b8c9d0e1f2',
   'Who was the Nobel laureate scientist credited with discovering Penicillin in 1928?',
   '["Marie Curie","Louis Pasteur","Alexander Fleming","Edward Jenner"]',
   2,
   'Sir Alexander Fleming discovered the world''s first active antibiotic, benzylpenicillin (penicillin), from the mold Penicillium notatum in 1928.[7]',
   'Science & Technology', 'CSS General Ability 2023', 'medium', true, 7, 'high', true),

  ('b3g30005-5555-4e5f-86a7-b8c9d0e1f2a3',
   'Which is the largest ocean in the world by surface area and volume?',
   '["Atlantic Ocean","Indian Ocean","Pacific Ocean","Arctic Ocean"]',
   2,
   'The Pacific Ocean is the largest and deepest of Earth''s oceanic divisions, extending from the Arctic Ocean in the north to the Southern Ocean in the south.[7]',
   'World Geography', 'FIA Inspector 2022', 'medium', true, 10, 'high', true),

  ('b3g30006-6666-4f6a-87b8-c9d0e1f2a3b4',
   'What is the correct chemical symbol for the element Gold?',
   '["Gd","Ag","Au","Pb"]',
   2,
   'The chemical symbol for Gold is Au, which originates from the Latin word ''aurum'', meaning shining dawn. Ag is silver, Pb is lead.[7]',
   'Science & Technology', 'NTS Junior Clerk 2023', 'medium', false, 0, 'medium', true),

  ('b3g30007-7777-4a7b-88c9-d0e1f2a3b4c5',
   'Who is the current Secretary-General of the United Nations (UN)?',
   '',
   2,
   'António Guterres of Portugal assumed office as the ninth Secretary-General of the United Nations on January 1, 2017.[7]',
   'International Orgs', 'KPPSC Planning Officer 2023', 'high', true, 9, 'high', true),

  ('b3g30008-8888-4b8c-89d0-e1f2a3b4c5d6',
   'The shores of the Dead Sea, bordering Jordan and Israel, represent which global geographical extreme?',
   '',
   1,
   'The shores of the Dead Sea represent the lowest exposed land elevation point on Earth, sitting at over 430 meters below sea level.',
   'World Geography', 'CSS General Ability 2023', 'high', true, 5, 'high', true),

  ('b3g30009-9999-4c9d-8012-f2a3b4c5d6e7',
   'The international headquarters of Amnesty International, the prominent human rights NGO, is located in which city?',
   '',
   0,
   'Amnesty International, which campaigns to end abuses of human rights worldwide, is headquartered in London, United Kingdom.',
   'International Orgs', 'KPPSC Assistant Sub-Inspector 2023', 'high', true, 6, 'high', true),

  ('b3g30010-aaaa-4d0e-81f2-a3b4c5d6e7f8',
   'In which major city is the famous suspension bridge ''Golden Gate'' located?',
   '',
   0,
   'The Golden Gate Bridge is an iconic suspension bridge spanning the Golden Gate strait in San Francisco, California.',
   'World Geography', 'FIA Assistant Sub-Inspector 2022', 'medium', true, 4, 'medium', true)

