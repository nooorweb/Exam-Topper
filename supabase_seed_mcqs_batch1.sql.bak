-- ─────────────────────────────────────────────────────────────
-- 4. Computer Science MCQs  →  computer_science_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.computer_science_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b3c30001-1111-4a1b-82c3-d4e5f6a7b8c9',
   'In the OSI model, which specific layer is responsible for data translation, compression, and encryption?',
   '',
   1,
   'The Presentation Layer (Layer 6) is responsible for formatting, translating, compressing, and encrypting data so it can be ready for transmission or application use.[8]',
   'Networking', 'ETEA Computer Operator 2024', 'high', true, 8, 'high', true),

  ('b3c30002-2222-4b2c-83d4-e5f6a7b8c9d0',
   'Which network protocol is specifically designed for transmitting and routing email messages over the internet?',
   '',
   2,
   'SMTP (Simple Mail Transfer Protocol) is the standard protocol explicitly used for sending and transferring email messages from client to server or between servers.[9]',
   'Networking', 'FIA Sub-Inspector IT 2023', 'medium', true, 6, 'high', true),

  ('b3c30003-3333-4c3d-84e5-f6a7b8c9d0e1',
   'In computer network administration, what does the acronym DHCP stand for?',
   '',
   1,
   'DHCP stands for Dynamic Host Configuration Protocol, which automatically assigns IP addresses and other network parameters to client devices.[9]',
   'Networking', 'KPPSC IT Officer 2023', 'medium', true, 5, 'high', true),

  ('b3c30004-4444-4d4e-85f6-a7b8c9d0e1f2',
   'In Microsoft Excel, which feature is utilized to copy the exact formatting of a selected cell and apply it to multiple other cells?',
   '',
   1,
   'The Format Painter tool in Microsoft Excel (and Word) allows you to copy all formatting attributes from one cell or selection and paint them onto another.',
   'MS Office', 'ETEA Computer Operator 2024', 'medium', true, 7, 'high', true),

  ('b3c30005-5555-4e5f-86a7-b8c9d0e1f2a3',
   'Which keyboard shortcut is used to open the ''Print'' configuration dialog box in Microsoft Word?',
   '',
   1,
   'Ctrl + P is the standard keyboard shortcut across almost all Windows applications, including Microsoft Word, to open the Print menu.',
   'MS Office', 'NTS Computer Operator 2022', 'medium', true, 4, 'medium', true),

  ('b3c30006-6666-4f6a-87b8-c9d0e1f2a3b4',
   'What is the default file system used by modern Microsoft Windows operating systems for disk formatting and storage?',
   '',
   2,
   'NTFS (New Technology File System) is the default file system for modern Windows, replacing the older FAT file system with advanced security, compression, and file-size support.[9]',
   'Operating Systems', 'FPSC Computer Operator 2023', 'high', true, 9, 'high', true),

  ('b3c30007-7777-4a7b-88c9-d0e1f2a3b4c5',
   'Which command is executed in the Windows Command Prompt (cmd) to clear all text and wipe the screen clean?',
   '["cls","clear","clr","clean"]',
   0,
   'The ''cls'' (clear screen) command is utilized in the Windows CLI command interpreter to clear all previous commands and output from the window.[9]',
   'Operating Systems', 'ETEA IT Officer 2022', 'medium', false, 0, 'medium', true),

  ('b3c30008-8888-4b8c-89d0-e1f2a3b4c5d6',
   'Which specific functional unit of the CPU is responsible for performing mathematical and logical comparison operations?',
   '',
   1,
   'The Arithmetic Logic Unit (ALU) is the digital circuit within the processor that executes all basic arithmetic (addition, subtraction) and logical operations.',
   'Computer Hardware', 'PPSC Programmer 2022', 'high', true, 6, 'high', true),

  ('b3c30009-9999-4c9d-8012-f2a3b4c5d6e7',
   'What is the primary function of high-speed Cache Memory in a modern computer system?',
   '',
   1,
   'Cache memory acts as an extremely fast intermediate buffer between the CPU and main memory (RAM), storing active data instructions to speed up processing cycles.[9]',
   'Computer Hardware', 'KPPSC IT Officer 2023', 'high', true, 8, 'high', true),

  ('b3c30010-aaaa-4d0e-81f2-a3b4c5d6e7f8',
   'Which intelligent Layer 2 networking device forwards data packets strictly to the target device by utilizing recorded MAC addresses?',
   '',
   1,
   'A Switch is an intelligent data link layer device that maps MAC addresses to forward data frames directly to the intended destination port, preventing packet collisions.[8]',
   'Networking', 'FIA Sub-Inspector IT 2023', 'high', true, 5, 'high', true)

