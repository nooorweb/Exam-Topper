-- ─────────────────────────────────────────────────────────────
-- 2. Pakistan Studies MCQs  →  pakistan_studies_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.pakistan_studies_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b2p20001-1111-4a1b-8b2c-d4e5f6a7b8c9',
   'On which exact date was the historic Objective Resolution formally adopted by the Constituent Assembly of Pakistan?',
   '["March 7, 1949","March 12, 1949","August 14, 1947","March 23, 1956"]',
   1,
   'While Prime Minister Liaquat Ali Khan presented the Objective Resolution to the Assembly on March 7, 1949, it was formally debated and adopted on March 12, 1949.',
   'Early History', 'CSS Pakistan Affairs 2023', 'high', true, 8, 'high', true),

  ('b2p20002-2222-4b2c-9c3d-e5f6a7b8c9d0',
   'The landmark Free Trade Agreement (FTA) between Pakistan and China was officially signed on:',
   '["November 24, 2006","December 31, 2005","January 15, 2007","October 18, 2008"]',
   0,
   'The comprehensive Free Trade Agreement between the two nations was signed on November 24, 2006, laying the early groundwork for enhanced bilateral economic corridors.',
   'Economy', 'FPSC ASI 2022', 'high', true, 4, 'medium', true),

  ('b2p20003-3333-4c3d-ad4e-f6a7b8c9d0e1',
   'Pakistan formally became an Islamic Republic when its first constitution was passed on:',
   '["March 23, 1956","August 14, 1956","January 1, 1957","March 23, 1957"]',
   0,
   'The 1956 Constitution of Pakistan was promulgated on March 23, 1956. This historic date formally transformed the Dominion of Pakistan into the Islamic Republic of Pakistan.',
   'Constitution', 'KPPSC PMS 2022', 'medium', true, 10, 'high', true),

  ('b2p20004-4444-4d4e-be5f-a7b8c9d0e1f2',
   'Under the revolutionary 7th National Finance Commission (NFC) Award, what is the allocated resource share for the province of Sindh?',
   '["51.74%","14.62%","24.55%","9.09%"]',
   2,
   'According to the 7th NFC Award formula, the divisible pool shares are: Punjab (51.74%), Sindh (24.55%), Khyber Pakhtunkhwa (14.62%), and Balochistan (9.09%).',
   'Governance', 'CSS Pakistan Affairs 2021', 'high', true, 5, 'high', true),

  ('b2p20005-5555-4e5f-cf6a-b8c9d0e1f2a3',
   'Under the 7th NFC Award formula, what is the fixed horizontal share allocated to the province of Balochistan?',
   '["51.74%","14.62%","24.55%","9.09%"]',
   3,
   'Balochistan receives exactly 9.09% of the provincial share of the divisible pool under the multi-indicator criteria established in the 7th NFC Award.',
   'Governance', 'KPPSC Tehsildar 2023', 'high', true, 4, 'high', true),

  ('b2p20006-6666-4f6a-a7b8-c9d0e1f2a3b4',
   'In the 7th NFC Award multi-criteria formula, what specific percentage weightage is assigned to ''Inverse Population Density''?',
   '["82.0%","10.3%","5.0%","2.7%"]',
   3,
   'The 7th NFC criteria weights are: Population (82.0%), Poverty/Backwardness (10.3%), Revenue Collection (5.0%), and Inverse Population Density (2.7%) which primarily benefits sparse provinces like Balochistan.',
   'Governance', 'FPSC Inspector 2024', 'high', true, 6, 'high', true),

  ('b2p20007-7777-4a7b-b8c9-d0e1f2a3b4c5',
   'Prior to the complete merger of FATA into KPK, the draconian Frontier Crimes Regulation (FCR) of 1901 was temporarily replaced by which document?',
   '["FATA Interim Governance Regulation, 2018","FATA Merger Act, 2017","FATA Reform Regulation, 2016","FATA Justice Regulation, 2015"]',
   0,
   'As part of the mainstreaming process, the President signed the FATA Interim Governance Regulation, 2018, which repealed and replaced the archaic FCR 1901 before the final constitutional merger.',
   'Governance', 'ETEA PST 2024', 'high', true, 3, 'high', true),

  ('b2p20008-8888-4b8c-c9d0-e1f2a3b4c5d6',
   'Which specific Article of the 1973 Constitution was amended by the 25th Amendment to eliminate the eight seats reserved for FATA in the Senate?',
   '["Article 51","Article 59","Article 62","Article 247"]',
   1,
   'Article 59 of the 1973 Constitution deals directly with the composition of the Senate. The 25th Amendment altered this article to eliminate the 8 FATA seats, reducing total membership to 96.',
   'Constitution', 'CSS Pakistan Affairs 2024', 'high', false, 0, 'high', true),

  ('b2p20009-9999-4c9d-d0e1-f2a3b4c5d6e7',
   'The Tarbela Dam, the largest earth-filled dam in the world, is constructed on which river?',
   '["Jhelum River","Chenab River","Indus River","Ravi River"]',
   2,
   'The Tarbela Dam is constructed across the mighty Indus River in the Swabi District of Khyber Pakhtunkhwa. It is the backbone of Pakistan''s irrigation and hydroelectric grid.',
   'Geography', 'NTS 2023', 'medium', true, 9, 'high', true),

  ('b2p2000a-aaaa-4d0e-e1f2-a3b4c5d6e7f8',
   'The Mangla Dam, one of Pakistan''s mega-hydrological projects built under the Indus Water Treaty, is located on which river?',
   '["Indus River","Jhelum River","Chenab River","Kabul River"]',
   1,
   'The Mangla Dam is a multipurpose dam located on the Jhelum River in the Mirpur District of Azad Kashmir.',
   'Geography', 'KPPSC Assistant Sub-Inspector 2022', 'medium', true, 7, 'high', true),

  ('b2p2000b-bbbb-4e1f-f2a3-b4c5d6e7f8a9',
   'The first phase of the construction of the Warsak Dam on the Kabul River was completed in which year?',
   '["1950","1960","1970","1980"]',
   1,
   'The Warsak Dam project in KPK was executed in two phases. The first operational phase was completed in 1960, and the second phase concluded in 1980-81.',
   'Geography', 'ETEA Computer Operator 2024', 'high', true, 5, 'medium', true),

  ('b2p2000c-cccc-4f2a-a3b4-c5d6e7f8a9b0',
   'The city and district of Mardan in Khyber Pakhtunkhwa is historically named after:',
   '["Pir Mardan Shah","Mardan Khan","Sardar Mardan Ali","Mardan Baba"]',
   0,
   'Mardan was named after Pir Mardan Shah, a highly prominent religious and spiritual figure. Gradually, the entire surrounding settlement adopted his name.',
   'Geography', 'KPPSC Tehsildar 2023', 'medium', false, 0, 'low', true),

  ('b2p2000d-dddd-4a3b-b4c5-d6e7f8a9b0c1',
   'The historically famous Wazir Khan Mosque is located in which city of Pakistan?',
   '["Peshawar","Multan","Lahore","Karachi"]',
   2,
   'The Wazir Khan Mosque is a 17th-century Mughal-era mosque located in the walled city of Lahore, Punjab. It is renowned for its intricate fresco and tile work.',
   'Geography', 'FIA Sub-Inspector 2023', 'medium', true, 6, 'medium', true),

  ('b2p2000e-eeee-4b4c-c5d6-e7f8a9b0c1d2',
   'The historic First Battle of Panipat, which led to the establishment of the Mughal Empire in the subcontinent, took place in the year:',
   '["1526","1556","1761","1857"]',
   0,
   'In 1526, Zahir-ud-din Babur decisively defeated the massive army of Ibrahim Lodi in the First Battle of Panipat, officially founding the Mughal dynasty in India.',
   'Early History', 'NTS Junior Clerk 2023', 'high', true, 8, 'high', true),

  ('b2p2000f-ffff-4c5d-d6e7-f8a9b0c1d2e3',
   'Which diplomatic agreement led to the formal end of the 1971 war between Pakistan and India?',
   '["Tashkent Agreement","Simla Agreement","Lahore Declaration","Delhi Accord"]',
   1,
   'The Simla Agreement (or Shimla Agreement) was signed in 1972 between Zulfiqar Ali Bhutto and Indira Gandhi, formally concluding the hostilities of the 1971 war.',
   'Early History', 'FPSC Inspector 2023', 'high', true, 5, 'high', true)

ON CONFLICT (id) DO UPDATE SET
  question       = EXCLUDED.question,
