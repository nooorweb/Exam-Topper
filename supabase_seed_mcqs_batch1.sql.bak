-- ============================================================
-- Exam Topper — MCQ Seed Data (AI Generated Batch 3)
-- Run AFTER Batch 1 & Batch 2 in the Supabase SQL Editor
-- Total: 60 MCQs (10 per subject) — Zero Repetition
-- Validated: UUIDs unique, correct_answer 0-3, JSON array fixed
-- ============================================================

-- ─────────────────────────────────────────────────────────────
-- 1. English MCQs  →  english_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.english_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b3e30001-1111-4a1b-82c3-d4e5f6a7b8c9',
   'Choose the correct synonym for the word ''BELLICOSE''.',
   '',
   2,
   '''Bellicose'' means demonstrating aggression and willingness to fight. ''Warlike'' is the correct synonym.[1]',
   'Vocabulary', 'CSS English 2022', 'high', true, 5, 'high', true),

  ('b3e30002-2222-4b2c-83d4-e5f6a7b8c9d0',
   'Choose the correct synonym for the word ''EPHEMERAL''.',
   '',
   2,
   '''Ephemeral'' means lasting for a very short time. ''Short-lived'' is the exact synonym often tested in competitive exams.[1]',
   'Vocabulary', 'CSS English 2020', 'high', true, 4, 'high', true),

  ('b3e30003-3333-4c3d-84e5-f6a7b8c9d0e1',
   'Select the exact antonym for the word ''OBSTINATE''.',
   '',
   2,
   '''Obstinate'' means stubbornly refusing to change one''s opinion. ''Pliant'' (flexible/yielding) is its direct antonym.[1]',
   'Vocabulary', 'CSS English 2022', 'high', true, 6, 'high', true),

  ('b3e30004-4444-4d4e-85f6-a7b8c9d0e1f2',
   'Choose the correct synonym for the word ''EQUIVOCAL''.',
   '',
   1,
   '''Equivocal'' means open to more than one interpretation; ambiguous or uncertain. ''Ambiguous'' is the exact synonym.[1]',
   'Vocabulary', 'CSS English 2022', 'high', false, 0, 'high', true),

  ('b3e30005-5555-4e5f-86a7-b8c9d0e1f2a3',
   'Choose the correct synonym for the word ''ALACRITY''.',
   '["Lethargy","Eagerness","Apathy","Indifference"]',
   1,
   '''Alacrity'' means brisk and cheerful readiness. ''Eagerness'' is the correct synonym.[2]',
   'Vocabulary', 'KPPSC PMS 2021', 'high', true, 3, 'medium', true),

  ('b3e30006-6666-4f6a-87b8-c9d0e1f2a3b4',
   'What is the meaning of the idiomatic expression ''To drive home''?',
   '',
   1,
   'The idiom ''To drive home'' means to emphasize an important point strongly so that it is fully understood by the audience.[3]',
   'Idioms & Phrases', 'KPPSC Tehsildar 2023', 'medium', true, 5, 'medium', true),

  ('b3e30007-7777-4a7b-88c9-d0e1f2a3b4c5',
   'Fill in the blank with the appropriate preposition: ''He is senior ________ me in service.''',
   '["than","to","from","by"]',
   1,
   'Adjectives ending in ''-ior'' (senior, junior, superior, inferior, prior) are grammatically followed by the preposition ''to'', not ''than''.',
   'Prepositions', 'ETEA Computer Operator 2024', 'medium', true, 8, 'high', true),

  ('b3e30008-8888-4b8c-89d0-e1f2a3b4c5d6',
   'Fill in the blank with the appropriate preposition: ''She is blind ________ her son''s faults.''',
   '["of","to","with","by"]',
   1,
   'When referring to a lack of perception or awareness rather than physical sight, ''blind'' is followed by the preposition ''to''.',
   'Prepositions', 'FPSC Inspector 2023', 'medium', true, 6, 'high', true),

  ('b3e30009-9999-4c9d-8012-f2a3b4c5d6e7',
   'Identify the grammatically correct sentence.',
   '',
   1,
   'The noun ''news'' is singular in construction and takes a singular verb. Thus, ''The news is true'' is correct.',
   'Sentence Correction', 'FIA Sub-Inspector 2022', 'medium', true, 7, 'high', true),

  ('b3e30010-aaaa-4d0e-81f2-a3b4c5d6e7f8',
   'What is the exact antonym for the word ''CAPRICIOUS''?',
   '["Fickle","Inconstant","Consistent","Volatile"]',
   2,
   '''Capricious'' means given to sudden and unaccountable changes of mood or behavior. Its exact opposite is ''Consistent'' or ''Stable''.[2]',
   'Vocabulary', 'FPSC ASI 2023', 'high', false, 0, 'medium', true)

ON CONFLICT (id) DO UPDATE SET
  question       = EXCLUDED.question,
