-- ─────────────────────────────────────────────────────────────
-- 3. General Knowledge MCQs  →  general_knowledge_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.general_knowledge_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b2g30001-1111-4a1b-8b2c-d4e5f6a7b8c9',
   'In September 2024, the Executive Board of the International Monetary Fund (IMF) approved an Extended Fund Facility (EFF) for Pakistan valued at:',
   '["$3 billion","$6 billion","$7 billion","$10 billion"]',
   2,
   'The IMF approved a comprehensive 37-month Extended Fund Facility (EFF) loan agreement for Pakistan valued at US$7 billion, intended for structural economic reforms.',
   'Current Affairs 2023-2025', 'FPSC ASI 2025', 'high', true, 4, 'high', true),

  ('b2g30002-2222-4b2c-9c3d-e5f6a7b8c9d0',
   'According to the IMF Country Report accompanying the 2024 EFF loan, what is Pakistan''s projected real GDP growth for the fiscal year 2026?',
   '["2.5%","3.0%","3.6%","4.2%"]',
   2,
   'The IMF projects Pakistan''s real GDP growth to stabilize at a modest 3.6% by the fiscal year 2026 under the strict conditions of the new financial arrangement.',
   'Current Affairs 2023-2025', 'CSS General Ability 2025', 'high', false, 0, 'high', true),

  ('b2g30003-3333-4c3d-ad4e-f6a7b8c9d0e1',
   'Which organ of the United Nations is considered the most powerful, possessing the authority to issue binding resolutions on member states?',
   '["General Assembly","Security Council","International Court of Justice","Secretariat"]',
   1,
   'The UN Security Council (UNSC) is the most powerful organ, responsible for maintaining international peace. Unlike the General Assembly, its resolutions are legally binding on all UN members.',
   'International Orgs', 'KPPSC Planning Officer 2023', 'high', true, 7, 'high', true),

  ('b2g30004-4444-4d4e-be5f-a7b8c9d0e1f2',
   'The international headquarters of Greenpeace, an independent global campaigning network for the environment, is located in:',
   '["London","Amsterdam","Paris","Berlin"]',
   1,
   'Greenpeace International, renowned for its direct actions addressing global environmental issues, is headquartered in Amsterdam, Netherlands.',
   'International Orgs', 'FIA Sub-Inspector 2022', 'medium', true, 4, 'medium', true),

  ('b2g30005-5555-4e5f-cf6a-b8c9d0e1f2a3',
   'World Press Freedom Day is observed globally every year on which date?',
   '["May 1","May 3","June 5","October 24"]',
   1,
   'The United Nations General Assembly declared May 3 as World Press Freedom Day to raise awareness regarding the absolute importance of freedom of the press.',
   'Important Dates', 'ETEA Police Constable 2024', 'medium', true, 6, 'medium', true),

  ('b2g30006-6666-4f6a-a7b8-c9d0e1f2a3b4',
   'What is the capital city of Canada?',
   '["Toronto","Ottawa","Vancouver","Montreal"]',
   1,
   'Ottawa is the capital city of Canada, located in the province of Ontario. It is a highly repeated geographic distractor in MCQs as candidates often wrongly guess Toronto.',
   'Capitals & Countries', 'NTS Clerk 2023', 'medium', true, 8, 'high', true),

  ('b2g30007-7777-4a7b-b8c9-d0e1f2a3b4c5',
   'By physical landmass, which is the largest island in the world?',
   '["Australia","Greenland","New Guinea","Borneo"]',
   1,
   'Greenland is geographically the world''s largest island. Australia is technically classified as a continental landmass, not an island.',
   'World Geography', 'FPSC ASI 2023', 'medium', true, 9, 'high', true),

  ('b2g30008-8888-4b8c-c9d0-e1f2a3b4c5d6',
   'The specific body of water that geographically separates Southern England from Northern France is called the:',
   '["Mediterranean Sea","North Sea","English Channel","Atlantic Ocean"]',
   2,
   'The English Channel is an arm of the Atlantic Ocean that separates Southern England from Northern France and links to the southern part of the North Sea.',
   'World Geography', 'KPPSC Tehsildar 2023', 'high', true, 5, 'medium', true),

  ('b2g30009-9999-4c9d-d0e1-f2a3b4c5d6e7',
   'The iconic ''Golden Gate Bridge'', a marvel of civil engineering, is located in which city?',
   '["Los Angeles","San Francisco","Seattle","Portland"]',
   1,
   'The Golden Gate Bridge is a massive suspension bridge spanning the one-mile-wide strait connecting San Francisco Bay to the Pacific Ocean in California.',
   'World Geography', 'FIA Inspector 2022', 'medium', true, 4, 'medium', true),

  ('b2g3000a-aaaa-4d0e-e1f2-a3b4c5d6e7f8',
   'Geographically, what is considered the absolute lowest exposed land point on the Earth''s surface?',
   '["Mariana Trench","Dead Sea","Death Valley","Lake Eyre"]',
   1,
   'The shores of the Dead Sea, bordering Jordan and Israel, mark the lowest exposed land point on the Earth''s surface. The Mariana Trench is the deepest oceanic point.',
   'World Geography', 'CSS General Ability 2023', 'high', true, 6, 'high', true),

  ('b2g3000b-bbbb-4e1f-f2a3-b4c5d6e7f8a9',
   'What is the deepest known oceanic point on Earth?',
   '["Dead Sea","Mariana Trench","Java Trench","Puerto Rico Trench"]',
   1,
   'The Mariana Trench, located in the western Pacific Ocean, is the deepest oceanic trench on Earth. The Challenger Deep is its lowest specific point.',
   'World Geography', 'ETEA SST General 2024', 'medium', true, 7, 'high', true),

  ('b2g3000c-cccc-4f2a-a3b4-c5d6e7f8a9b0',
   'The international headquarters of Amnesty International, a prominent global human rights watchdog, is located in:',
   '["New York","Geneva","London","Paris"]',
   2,
   'Amnesty International is a massive non-governmental organization focused solely on global human rights, and its central operational headquarters is based in London, UK.',
   'International Orgs', 'KPPSC Assistant Sub-Inspector 2023', 'high', true, 5, 'high', true),

  ('b2g3000d-dddd-4a3b-b4c5-d6e7f8a9b0c1',
   'What is the highest topological point on Earth above sea level?',
   '["K2","Kangchenjunga","Mount Everest","Makalu"]',
   2,
   'Mount Everest, located in the Himalayas on the border between Nepal and China, is Earth''s highest mountain above sea level (8,848 meters).',
   'World Geography', 'NTS 2023', 'medium', true, 10, 'high', true),

  ('b2g3000e-eeee-4b4c-c5d6-e7f8a9b0c1d2',
   'Which major global city hosted the 2024 Summer Olympics?',
   '["Los Angeles","Paris","Tokyo","London"]',
   1,
   'The 2024 Summer Olympics, officially the Games of the XXXIII Olympiad, were hosted by Paris, France. Los Angeles is slated for 2028.',
   'Sports', 'FPSC Inspector 2024', 'medium', false, 0, 'high', true),

  ('b2g3000f-ffff-4c5d-d6e7-f8a9b0c1d2e3',
   'Which Asian country is globally referred to as the ''Land of the Rising Sun''?',
   '["China","Japan","South Korea","Vietnam"]',
   1,
   'Japan is famously called the ''Land of the Rising Sun'', derived from the translation of its native name ''Nippon'' or ''Nihon'', indicating the sun''s origin relative to China.',
   'World Geography', 'FIA Assistant Sub-Inspector 2022', 'medium', true, 8, 'medium', true)

ON CONFLICT (id) DO UPDATE SET
  question       = EXCLUDED.question,
  options        = EXCLUDED.options,
  correct_answer = EXCLUDED.correct_answer,
  explanation    = EXCLUDED.explanation,
  subcategory    = EXCLUDED.subcategory,
  exam_type      = EXCLUDED.exam_type,
  difficulty     = EXCLUDED.difficulty,
  is_repeated    = EXCLUDED.is_repeated,
  repeat_count   = EXCLUDED.repeat_count,
  importance     = EXCLUDED.importance,
  is_public      = EXCLUDED.is_public;


-- ─────────────────────────────────────────────────────────────
-- 4. Computer Science MCQs  →  computer_science_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.computer_science_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b2c40001-1111-4a1b-8b2c-d4e5f6a7b8c9',
   'In the strict OSI networking model, which specific layer is primarily responsible for data encryption and compression?',
   '["Network Layer","Presentation Layer","Transport Layer","Session Layer"]',
   1,
   'The Presentation Layer (Layer 6) acts as the data translator for the network. It handles syntax processing, data compression, and vital security encryption before passing to the Application Layer.',
   'Networking', 'PPSC Network Engineer 2024', 'high', true, 6, 'high', true),

  ('b2c40002-2222-4b2c-9c3d-e5f6a7b8c9d0',
   'In network security and configuration, what is the primary function of NAT (Network Address Translation)?',
   '["Filtering packets","Mapping private IPs to public IPs","Routing between networks","Encrypting data"]',
   1,
   'NAT operates on routers to map multiple private, internal IP addresses to a single, internet-facing public IP address, conserving IP space and adding a layer of security.',
   'Networking', 'KPPSC IT Officer 2023', 'high', true, 5, 'high', true),

  ('b2c40003-3333-4c3d-ad4e-f6a7b8c9d0e1',
   'What is the fundamental operational difference between a Network Hub and a Switch?',
   '["Hub broadcasts, Switch forwards intelligently","Hub is faster than Switch","Switch broadcasts, Hub forwards","Both work exactly the same"]',
   0,
   'A Hub operates blindly at Layer 1, broadcasting incoming data to all connected ports, causing collisions. A Switch (Layer 2) learns MAC addresses and forwards data efficiently only to the intended recipient.',
   'Networking', 'ETEA Computer Operator 2024', 'medium', true, 8, 'high', true),

  ('b2c40004-4444-4d4e-be5f-a7b8c9d0e1f2',
   'Which of the following protocols operates explicitly at the Application Layer of the OSI Model to handle email transmissions?',
   '["TCP","SMTP","IP","UDP"]',
   1,
   'SMTP (Simple Mail Transfer Protocol) is an Application Layer protocol strictly responsible for the sending and routing of email messages over the internet.',
   'Networking', 'FIA Sub-Inspector IT 2023', 'medium', true, 4, 'medium', true),

  ('b2c40005-5555-4e5f-cf6a-b8c9d0e1f2a3',
   'When comparing the two primary Transport Layer protocols, which defining characteristic separates TCP from UDP?',
   '["TCP is connectionless, UDP is connection-oriented","TCP guarantees delivery, UDP does not","UDP has error checking, TCP does not","Both use handshakes"]',
   1,
   'TCP establishes a strict, connection-oriented handshake to guarantee error-free data delivery. UDP is connectionless, prioritizing high-speed transmission (like video streaming) over guaranteed delivery.',
   'Networking', 'FPSC Computer Operator 2023', 'high', true, 7, 'high', true),

  ('b2c40006-6666-4f6a-a7b8-c9d0e1f2a3b4',
   'In Microsoft PowerPoint, what is the specific keyboard shortcut to create a brand new, blank presentation file?',
   '["Ctrl + M","Ctrl + N","Ctrl + P","Ctrl + S"]',
   1,
   'Ctrl + N opens an entirely New presentation document window. Note that this is frequently confused with Ctrl + M, which inserts a new slide into the existing presentation.',
   'MS Office', 'NTS Computer Operator 2022', 'medium', true, 9, 'high', true),

  ('b2c40007-7777-4a7b-b8c9-d0e1f2a3b4c5',
   'In Microsoft PowerPoint, which shortcut key is used to insert a new slide into the currently active presentation sequence?',
   '["Ctrl + N","Ctrl + M","Ctrl + S","Ctrl + D"]',
   1,
   'Ctrl + M is the shortcut specifically assigned to insert a new slide into your current slide deck. Ctrl + N opens a new presentation entirely.',
   'MS Office', 'ETEA Computer Operator 2024', 'medium', true, 6, 'high', true),

  ('b2c40008-8888-4b8c-c9d0-e1f2a3b4c5d6',
   'When printing a massive dataset in Microsoft Excel, which feature allows you to lock a specific row so it repeats at the top of every printed page?',
   '["Freeze Panes","Print Titles","Page Break Preview","Header Row"]',
   1,
   'The ''Print Titles'' feature in Excel allows users to designate specific rows or columns to repeat on every printed page, making multi-page data sheets readable.',
   'MS Office', 'KPPSC Assistant Sub-Inspector 2023', 'high', true, 5, 'high', true),

  ('b2c40009-9999-4c9d-d0e1-f2a3b4c5d6e7',
   'In the Windows Operating System, which keyboard combination permanently deletes a file, bypassing the Recycle Bin completely?',
   '["Ctrl + Delete","Shift + Delete","Alt + Delete","Windows + Delete"]',
   1,
   'Pressing Shift + Delete on a selected file or folder permanently erases it from the storage drive, skipping the safety net of the Recycle Bin.',
   'Operating Systems', 'FIA Sub-Inspector IT 2023', 'medium', true, 10, 'high', true),

  ('b2c4000a-aaaa-4d0e-e1f2-a3b4c5d6e7f8',
   'In the Windows command prompt (cmd), which command is executed to clear all text and visual clutter from the screen?',
   '["clear","clrscr","cls","clean"]',
   2,
   'The ''cls'' (clear screen) command is used in the Windows command-line interface to wipe the terminal window clean.',
   'Operating Systems', 'ETEA IT Officer 2022', 'medium', false, 0, 'medium', true),

  ('b2c4000b-bbbb-4e1f-f2a3-b4c5d6e7f8a9',
   'What is the default, modern file system utilized by the Microsoft Windows Operating System?',
   '["FAT32","NTFS","exFAT","HFS+"]',
   1,
   'NTFS (New Technology File System) is the primary, default file system for recent versions of Windows, offering advanced security permissions and large file support compared to older FAT32 systems.',
   'Operating Systems', 'FPSC Computer Operator 2023', 'high', true, 4, 'high', true),

  ('b2c4000c-cccc-4f2a-a3b4-c5d6e7f8a9b0',
   'Within the hierarchy of computer hardware memory, what is the primary function of Cache Memory?',
   '["Permanent storage","Speeds up CPU access to frequently used data","Connects to the internet","Displays graphics"]',
   1,
   'Cache memory acts as an ultra-fast buffer directly between the CPU and the slower RAM. It temporarily stores the most frequently accessed data instructions for instantaneous retrieval, massively speeding up processing.',
   'Computer Hardware', 'KPPSC IT Officer 2023', 'high', true, 7, 'high', true),

  ('b2c4000d-dddd-4a3b-b4c5-d6e7f8a9b0c1',
   'Which specific hardware device is responsible for converting digital signals from a computer into analog signals suitable for transmission over telephone lines, and vice versa?',
   '["Router","Switch","Modem","Gateway"]',
   2,
   'A Modem (Modulator-Demodulator) modulates outgoing digital signals into analog format for wire transmission, and demodulates incoming analog signals back into digital data for the computer.',
   'Computer Hardware', 'NTS Computer Operator 2022', 'medium', true, 8, 'high', true),

  ('b2c4000e-eeee-4b4c-c5d6-e7f8a9b0c1d2',
   'In the historical evolution of programming languages, ''First Generation Language'' (1GL) is synonymous with:',
   '["Assembly Language","Machine Code","C Language","Python"]',
   1,
   'First Generation Languages are the lowest level of computing language, consisting entirely of raw binary machine code (1s and 0s) directly executable by the CPU without a compiler.',
   'Programming Basics', 'ETEA Computer Operator 2024', 'high', true, 3, 'high', true),

  ('b2c4000f-ffff-4c5d-d6e7-f8a9b0c1d2e3',
   'If a computer architecture utilizes an 8-bit address bus, what is the absolute maximum memory capacity it can logically address?',
   '["128 bytes","256 bytes","512 bytes","1024 bytes"]',
   1,
   'The total number of memory locations an address bus can access is 2 raised to the power of the number of lines. Therefore, 2^8 equals exactly 256 addressable bytes.',
   'Computer Hardware', 'PPSC Programmer 2022', 'high', true, 4, 'high', true)

ON CONFLICT (id) DO UPDATE SET
  question       = EXCLUDED.question,
  options        = EXCLUDED.options,
  correct_answer = EXCLUDED.correct_answer,
  explanation    = EXCLUDED.explanation,
  subcategory    = EXCLUDED.subcategory,
  exam_type      = EXCLUDED.exam_type,
  difficulty     = EXCLUDED.difficulty,
  is_repeated    = EXCLUDED.is_repeated,
  repeat_count   = EXCLUDED.repeat_count,
  importance     = EXCLUDED.importance,
  is_public      = EXCLUDED.is_public;


-- ─────────────────────────────────────────────────────────────
-- 5. Mathematics MCQs  →  mathematics_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.mathematics_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b2m50001-1111-4a1b-8b2c-d4e5f6a7b8c9',
   'By strict mathematical definition, a prime number is a natural number greater than 1 that:',
   '["Is divisible only by 2","Always ends in 3, 7, or 9","Is divisible only by 1 and itself","Has a minimum of three distinct factors"]',
   2,
   'A prime number has exactly two positive divisors: 1 and the number itself. For example, 2, 3, 5, 7, 11 are primes. Number 1 is not considered prime.',
   'Number System', 'NTS 2023', 'medium', true, 8, 'high', true),

  ('b2m50002-2222-4b2c-9c3d-e5f6a7b8c9d0',
   'In standard mathematics and programming functions like BASIC, the LOG function generally calculates a natural logarithm. What is its mathematical base?',
   '["10","2","e","pi"]',
   2,
   'The natural logarithm (often written as LN or LOG depending on the system syntax) strictly uses the mathematical constant ''e'' (Euler''s number, approx 2.718) as its base.',
   'Algebra', 'KPPSC Tehsildar 2023', 'high', true, 3, 'medium', true),

  ('b2m50003-3333-4c3d-ad4e-f6a7b8c9d0e1',
   'Which ancient Greek mathematician is historically celebrated as the undisputed ''Father of Geometry''?',
   '["Pythagoras","Euclid","Archimedes","Aristotle"]',
   1,
   'Euclid of Alexandria is known as the father of geometry. His textbook ''Elements'' was used as the primary mathematics textbook for over 2000 years.',
   'Geometry', 'CSS General Ability 2023', 'medium', true, 5, 'medium', true),

  ('b2m50004-4444-4d4e-be5f-a7b8c9d0e1f2',
   'A binary transmission channel operates at a speed of 8000 bps. If you need to transmit a file exactly 1 Kilobyte (KB) in size (assuming 1 KB = 8000 bits), how long will the transmission take?',
   '["0.5 seconds","1 second","8 seconds","10 seconds"]',
   1,
   'Because the data file is exactly 8000 bits, and the network channel transmits exactly 8000 bits per second (bps), the entire file will take exactly 1 second to transmit (8000 / 8000 = 1).',
   'Algebra', 'ETEA Computer Operator 2024', 'high', true, 4, 'high', true),

  ('b2m50005-5555-4e5f-cf6a-b8c9d0e1f2a3',
   'If a perfect geometric square is rotated exactly 90 degrees on its central axis, what shape does its physical outline become?',
   '["Rectangle","Diamond","Square","Rhombus"]',
   2,
   'A square possesses a rotational symmetry of order 4. Rotating it by 90, 180, or 270 degrees perfectly overlaps its original shape, meaning it strictly remains a square.',
   'Geometry', 'ETEA Junior Clerk 2024', 'medium', false, 0, 'low', true),

  ('b2m50006-6666-4f6a-a7b8-c9d0e1f2a3b4',
   'Calculate the Highest Common Factor (HCF) of the numbers 12, 15, and 21.',
   '["2","3","4","5"]',
   1,
   'The factors of 12 are (1,2,3,4,6,12). Factors of 15 are (1,3,5,15). Factors of 21 are (1,3,7,21). The highest number common to all three lists is 3.',
   'Number System', 'KPPSC Assistant Sub-Inspector 2023', 'medium', true, 6, 'high', true),

  ('b2m50007-7777-4a7b-b8c9-d0e1f2a3b4c5',
   'The average age of 5 students is 20 years. If one student is excluded, the new average age of the remaining 4 students becomes 22 years. What is the age of the excluded student?',
   '["10 years","12 years","14 years","16 years"]',
   1,
   'Total age of 5 students = 5 * 20 = 100 years. Total age of remaining 4 students = 4 * 22 = 88 years. Therefore, age of excluded student = 100 - 88 = 12 years.',
   'Averages', 'FPSC Inspector 2024', 'high', true, 7, 'high', true),

  ('b2m50008-8888-4b8c-c9d0-e1f2a3b4c5d6',
   'If 30% of an unknown number is equal to 120, what is the complete number?',
   '["300","360","400","420"]',
   2,
   'Let the number be x. 30% of x = 120. Equation: (30/100) * x = 120. Solving for x gives x = 120 * (100/30) = 400.',
   'Percentages', 'ETEA SST General 2024', 'high', true, 9, 'high', true),

  ('b2m50009-9999-4c9d-d0e1-f2a3b4c5d6e7',
   'Two numbers exist in the ratio of 3:4. If their total sum equals 70, what is the value of the larger number?',
   '["30","40","50","60"]',
   1,
   'Let the numbers be 3x and 4x. Sum = 3x + 4x = 7x. We know 7x = 70, therefore x = 10. The larger number is 4x, which equals 4 * 10 = 40.',
   'Ratios & Proportions', 'FIA Sub-Inspector 2022', 'medium', true, 6, 'high', true),

  ('b2m5000a-aaaa-4d0e-e1f2-a3b4c5d6e7f8',
   'A shopkeeper buys an item for Rs. 500 (Cost Price) and sells it for Rs. 600 (Selling Price). What is his exact profit percentage?',
   '["10%","15%","20%","25%"]',
   2,
   'Profit = Selling Price - Cost Price = 600 - 500 = 100. Profit Percentage = (Profit / Cost Price) * 100 = (100 / 500) * 100 = 20%.',
   'Percentages', 'KPPSC Tehsildar 2023', 'medium', true, 8, 'high', true),

  ('b2m5000b-bbbb-4e1f-f2a3-b4c5d6e7f8a9',
   'A fast-moving train that is exactly 100 meters long completely passes a stationary pole in 10 seconds. What is the speed of the train in meters per second (m/s)?',
   '["5 m/s","10 m/s","15 m/s","20 m/s"]',
   1,
   'Speed = Distance / Time. The distance the train must travel to clear the pole is its own length (100m). Speed = 100 meters / 10 seconds = 10 m/s.',
   'Speed & Distance', 'NTS 2023', 'medium', true, 5, 'medium', true),

  ('b2m5000c-cccc-4f2a-a3b4-c5d6e7f8a9b0',
   'Solve the linear algebraic equation: 2x + 5 = 15',
   '["3","4","5","6"]',
   2,
   'Isolate the variable x: First, subtract 5 from both sides to get 2x = 10. Then, divide both sides by 2 to find x = 5.',
   'Algebra', 'ETEA Police Constable 2024', 'medium', true, 4, 'medium', true),

  ('b2m5000d-dddd-4a3b-b4c5-d6e7f8a9b0c1',
   'Calculate the area of a standard triangle that has a base of 10 cm and a vertical height of 5 cm.',
   '["15 cm²","20 cm²","25 cm²","30 cm²"]',
   2,
   'The formula for the area of a triangle is Area = (1/2) * base * height. Plugging in the values: Area = (1/2) * 10 * 5 = 25 cm².',
   'Geometry', 'CSS General Ability 2022', 'medium', true, 3, 'medium', true),

  ('b2m5000e-eeee-4b4c-c5d6-e7f8a9b0c1d2',
   'Calculate the Least Common Multiple (LCM) of the digits 4, 6, and 8.',
   '["12","18","24","32"]',
   2,
   'Multiples of 4 are 4, 8, 12, 16, 20, 24. Multiples of 6 are 6, 12, 18, 24. Multiples of 8 are 8, 16, 24. The lowest number appearing in all three lists is 24.',
   'Number System', 'FPSC ASI 2022', 'medium', true, 6, 'high', true),

  ('b2m5000f-ffff-4c5d-d6e7-f8a9b0c1d2e3',
   'Worker A can finish a project alone in 10 days. Worker B can finish the exact same project alone in 15 days. If they work together, how many days will it take them?',
   '["5 days","6 days","7 days","8 days"]',
   1,
   'Worker A''s daily rate is 1/10. Worker B''s daily rate is 1/15. Combined rate = 1/10 + 1/15 = 3/30 + 2/30 = 5/30 = 1/6 of the work per day. Therefore, they finish in 6 days.',
   'Time & Work', 'KPPSC PMS 2021', 'high', true, 10, 'high', true)

ON CONFLICT (id) DO UPDATE SET
  question       = EXCLUDED.question,
  options        = EXCLUDED.options,
  correct_answer = EXCLUDED.correct_answer,
  explanation    = EXCLUDED.explanation,
  subcategory    = EXCLUDED.subcategory,
  exam_type      = EXCLUDED.exam_type,
  difficulty     = EXCLUDED.difficulty,
  is_repeated    = EXCLUDED.is_repeated,
  repeat_count   = EXCLUDED.repeat_count,
  importance     = EXCLUDED.importance,
  is_public      = EXCLUDED.is_public;


-- ─────────────────────────────────────────────────────────────
-- 6. Islamiat MCQs  →  islamiat_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.islamiat_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b2i60001-1111-4a1b-8b2c-d4e5f6a7b8c9',
   'What is the real, full name of Imam Bukhari, the compiler of the most authentic collection of Hadith?',
   '["Muhammad bin Ismail","Ahmad bin Hanbal","Muslim bin Hajjaj","Malik bin Anas"]',
   0,
   'Imam Bukhari''s full name was Abu Abdullah Muhammad bin Ismail. His compilation, Sahih al-Bukhari, is considered the most authentic book after the Holy Quran in Sunni Islam.',
   'Hadith & Sunnah', 'CSS Islamiat Optional 2022', 'high', true, 6, 'high', true),

  ('b2i60002-2222-4b2c-9c3d-e5f6a7b8c9d0',
   'The historic Battle of Uhud, where Muslims faced a severe test of discipline, took place in which Islamic calendar year?',
   '["2 AH","3 AH","4 AH","5 AH"]',
   1,
   'The Battle of Uhud occurred in the 3rd year of the Hijri calendar (3 AH), exactly one year after the foundational Battle of Badr.',
   'Seerat-un-Nabi', 'KPPSC Tehsildar 2023', 'medium', true, 8, 'high', true),

  ('b2i60003-3333-4c3d-ad4e-f6a7b8c9d0e1',
   'The profound Treaty of Hudaybiyyah, a pivotal 10-year peace agreement between Muslims and the Quraysh, was signed in which Hijri year?',
   '["5 AH","6 AH","7 AH","8 AH"]',
   1,
   'The Treaty of Hudaybiyyah was negotiated and signed in 6 AH. It is termed ''Fath-e-Mubeen'' (a clear victory) in the Quran for the diplomatic recognition it gave to the Islamic State.',
   'Seerat-un-Nabi', 'FPSC Islamiat Paper 2023', 'high', true, 7, 'high', true),

  ('b2i60004-4444-4d4e-be5f-a7b8c9d0e1f2',
   'The triumphant Conquest of Makkah (Fath Makkah) by Prophet Muhammad (PBUH) without bloodshed took place in:',
   '["7 AH","8 AH","9 AH","10 AH"]',
   1,
