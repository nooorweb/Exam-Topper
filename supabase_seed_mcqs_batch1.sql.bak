-- ─────────────────────────────────────────────────────────────
-- 6. Islamiat MCQs  →  islamiat_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.islamiat_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b3i30001-1111-4a1b-82c3-d4e5f6a7b8c9',
   'Which deeply revered Surah of the Holy Quran is known by the title ''Umm-ul-Quran'' (Mother of the Quran)?',
   '',
   0,
   'Surah Al-Fatiha is referred to as Umm-ul-Quran or Umm-ul-Kitab because it comprehensively encapsulates the essential themes and core prayers of the entire Quran.',
   'Holy Quran', 'NTS 2023', 'medium', true, 7, 'high', true),

  ('b3i30002-2222-4b2c-83d4-e5f6a7b8c9d0',
   'The compilation of the Holy Quran into a single standardized book form (Mushaf) was primarily completed during the caliphate of which Rightly Guided Caliph?',
   '',
   2,
   'While Hazrat Abu Bakr (RA) initiated the collection of Quranic writings, it was Hazrat Usman (RA) who compiled them into a single, standardized book form based on the Quraysh dialect.',
   'Islamic History', 'ETEA Computer Operator 2024', 'high', true, 6, 'high', true),

  ('b3i30003-3333-4c3d-84e5-f6a7b8c9d0e1',
   'The historic Battle of Uhud, where Muslims faced a severe test of discipline, occurred in which Hijri calendar year?',
   '["2 AH","3 AH","4 AH","5 AH"]',
   1,
   'The Battle of Uhud took place in Shawwal of 3 AH (approximately 625 CE), exactly one year after the landmark Battle of Badr.',
   'Seerat-un-Nabi', 'KPPSC Tehsildar 2023', 'medium', true, 8, 'high', true),

  ('b3i30004-4444-4d4e-85f6-a7b8c9d0e1f2',
   'Who holds the honor of being the very first female martyr (Shaheed) in the history of Islam?',
   '',
   1,
   'Hazrat Sumayyah bint Khayyat (RA), the mother of Hazrat Ammar ibn Yasir (RA), was the first martyr of Islam. She was tortured to death by Abu Jahl.',
   'Islamic Personalities', 'KPPSC PMS 2021', 'high', true, 8, 'high', true),

  ('b3i30005-5555-4e5f-86a7-b8c9d0e1f2a3',
   'Linguistically and technically, what is the literal meaning of the word ''Hadith''?',
   '',
   1,
   'Linguistically, the Arabic word ''Hadith'' means a saying, talk, narrative, or report. In Islamic Fiqh, it refers to the records of the words, actions, and approvals of the Prophet (PBUH).',
   'Hadith & Sunnah', 'FPSC Islamiat Paper 2023', 'medium', false, 0, 'medium', true),

  ('b3i30006-6666-4f6a-87b8-c9d0e1f2a3b4',
   'Which prominent companion accompanied Prophet Muhammad (PBUH) during his stay in the Cave of Thawr during the Hijrat to Madinah?',
   '',
   2,
   'Hazrat Abu Bakr Al-Siddiq (RA) was the sole companion who accompanied the Prophet (PBUH) in the Cave of Thawr during the historic migration (Hijrat).',
   'Islamic Personalities', 'CSS Pakistan Affairs 2021', 'medium', true, 6, 'high', true),

  ('b3i30007-7777-4a7b-88c9-d0e1f2a3b4c5',
   'For structural ease of reading and recitation, the Holy Quran is divided into how many equal segments, known as Paras or Juz?',
   '["10 Paras","20 Paras","30 Paras","40 Paras"]',
   2,
   'The Holy Quran is systematically divided into exactly 30 equal parts, known as Paras (in Persian/Urdu) or Juz (in Arabic), facilitating complete recitation.',
   'Holy Quran', 'FIA Inspector 2022', 'medium', true, 6, 'medium', true),

  ('b3i30008-8888-4b8c-89d0-e1f2a3b4c5d6',
   'The very first revelation (Wahi) sent down to Prophet Muhammad (PBUH) in the Cave of Hira belongs to which Surah?',
   '',
   2,
   'The first five verses of Surah Al-Alaq (Read in the name of your Lord...) were the initial revelation delivered to the Prophet (PBUH) by the Angel Jibril.',
   'Quran Revelation', 'FIA Sub-Inspector 2022', 'high', true, 8, 'high', true),

  ('b3i30009-9999-4c9d-8012-f2a3b4c5d6e7',
   'Hajj, the fifth pillar of Islam, was made obligatory on Muslims in which Hijri year?',
   '["6th Hijri","8th Hijri","9th Hijri","10th Hijri"]',
   2,
   'Hajj was declared compulsory in the 9th year of the Hijrah calendar (9 AH). The Prophet (PBUH) performed his Farewell Hajj in 10 AH.',
   'Fiqh & Pillars', 'KPPSC Assistant Sub-Inspector 2023', 'high', true, 5, 'high', true),

  ('b3i30010-aaaa-4d0e-81f2-a3b4c5d6e7f8',
   'According to Islamic jurisprudence, what is the prescribed Nisab threshold for Zakat on pure Silver?',
   '',
   2,
   'The Nisab for silver is exactly 52.5 Tolas (approximately 612.36 grams), above which a Zakat rate of 2.5% is mandatory annually.',
   'Fiqh & Pillars', 'KPPSC Tehsildar 2023', 'high', true, 10, 'high', true)

ON CONFLICT (id) DO UPDATE SET
  question       = EXCLUDED.question,
  options        = EXCLUDED.options,
  correct_answer = EXCLUDED.correct_answer,
  explanation    = EXCLUDED.explanation,
