-- ─────────────────────────────────────────────────────────────
-- 1. English MCQs  →  english_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.english_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b2e10001-1111-4a1b-8b2c-d4e5f6a7b8c9',
   'Choose the correct synonym for the word ''TUMULT''.',
   '["Order","Commotion","Silence","Peace"]',
   1,
   '''Tumult'' refers to a loud, confused noise, especially one caused by a large mass of people. ''Commotion'' is the exact synonym often tested in FPSC exams.',
   'Vocabulary', 'CSS English 2022', 'high', true, 6, 'high', true),

  ('b2e10002-2222-4b2c-9c3d-e5f6a7b8c9d0',
   'What is the exact antonym for the word ''DENIGRATE''?',
   '["Criticize","Praise","Insult","Blame"]',
   1,
   '''Denigrate'' means to criticize unfairly or disparage. Therefore, ''Praise'' or ''Commend'' is its direct antonym.',
   'Vocabulary', 'KPPSC PMS 2021', 'high', true, 5, 'high', true),

  ('b2e10003-3333-4c3d-ad4e-f6a7b8c9d0e1',
   'Select the antonym for the word ''TORTUOUS''.',
   '["Curved","Straightforward","Twisted","Complex"]',
   1,
   '''Tortuous'' means full of twists and turns, or highly complex. The antonym is ''Straightforward'' or ''Simple''.',
   'Vocabulary', 'FIA Sub-Inspector 2023', 'high', false, 0, 'medium', true),

  ('b2e10004-4444-4d4e-be5f-a7b8c9d0e1f2',
   'Choose the correct synonym for the word ''VOCIFEROUS''.',
   '["Quiet","Loud","Gentle","Soft"]',
   1,
   '''Vociferous'' means crying out noisily or expressing opinions in a very loud, forceful way. ''Loud'' or ''Clamorous'' are synonyms.',
   'Vocabulary', 'ETEA SST General 2024', 'high', true, 4, 'high', true),

  ('b2e10005-5555-4e5f-cf6a-b8c9d0e1f2a3',
   'What is the antonym of ''PUSILLANIMOUS''?',
   '["Cowardly","Brave","Timid","Fearful"]',
   1,
   '''Pusillanimous'' means showing a lack of courage or determination; cowardly. The correct antonym is ''Brave'' or ''Valiant''.',
   'Vocabulary', 'FPSC Inspector 2023', 'high', true, 7, 'high', true),

  ('b2e10006-6666-4f6a-a7b8-c9d0e1f2a3b4',
   'What does the idiom ''A cat in gloves catches no mice'' mean?',
   '["Being too careful prevents success","Cats are dangerous","Mice are clever","Gloves are useful"]',
   0,
   'This idiom means that you cannot get what you need or accomplish your goals if you are too careful, excessively polite, or afraid to get your hands dirty.',
   'Idioms & Phrases', 'NTS Junior Clerk 2022', 'medium', true, 3, 'medium', true),

  ('b2e10007-7777-4a7b-b8c9-d0e1f2a3b4c5',
   'What does the idiom ''At the eleventh hour'' signify?',
   '["Early morning","Last possible moment","Midnight","Noon"]',
   1,
   'The phrase ''At the eleventh hour'' means something happening at the very last possible moment before a deadline or a critical event.',
   'Idioms & Phrases', 'KPPSC Tehsildar 2023', 'medium', true, 8, 'high', true),

  ('b2e10008-8888-4b8c-c9d0-e1f2a3b4c5d6',
   'Choose the correct meaning of the idiom ''At wit''s end''.',
   '["Very intelligent","Frustrated because all measures failed","End of a journey","A funny joke"]',
   1,
   'To be ''at your wit''s end'' means to be completely frustrated, confused, and devoid of ideas because all prior attempts to solve a problem have failed.',
   'Idioms & Phrases', 'ETEA Computer Operator 2024', 'high', true, 5, 'high', true),

  ('b2e10009-9999-4c9d-d0e1-f2a3b4c5d6e7',
   'If someone is described as a ''Cold fish'', they are:',
   '["Warm and friendly","Distant and unfeeling","Generous","Helpful"]',
   1,
   'In English idioms, a ''Cold fish'' describes a person who is distant, unfeeling, and not easily moved by emotions.',
   'Idioms & Phrases', 'FPSC ASI 2022', 'medium', false, 0, 'low', true),

  ('b2e1000a-aaaa-4d0e-e1f2-a3b4c5d6e7f8',
   'What does it mean if a situation is ''At sixes and sevens''?',
   '["Perfect order","A state of confusion","Playing cards","Mathematical error"]',
   1,
   'The idiom ''At sixes and sevens'' denotes a profound state of confusion, disarray, or a total lack of organizational coherence.',
   'Idioms & Phrases', 'CSS English 2021', 'high', true, 6, 'high', true),

  ('b2e1000b-bbbb-4e1f-f2a3-b4c5d6e7f8a9',
   'Identify the correct antonym for the word ''PLACID''.',
   '["Calm","Turbulent","Peaceful","Serene"]',
   1,
   '''Placid'' means not easily upset or excited; calm and peaceful. The antonym is ''Turbulent'', ''Agitated'', or ''Active''.',
   'Vocabulary', 'KPPSC Assistant Sub-Inspector 2023', 'medium', true, 4, 'medium', true),

  ('b2e1000c-cccc-4f2a-a3b4-c5d6e7f8a9b0',
   'Choose the exact synonym for the word ''THWART''.',
   '["Assist","Prevent","Help","Encourage"]',
   1,
   '''Thwart'' means to aggressively prevent someone from accomplishing something. ''Prevent'' or ''Stop'' is the correct synonym.',
   'Vocabulary', 'ETEA SST 2022', 'high', true, 5, 'high', true),

  ('b2e1000d-dddd-4a3b-b4c5-d6e7f8a9b0c1',
   'Select the synonym for the word ''ZEALOT''.',
   '["Fanatic","Moderate","Atheist","Pacifist"]',
   0,
   'A ''Zealot'' is a person who is fanatical and uncompromising in pursuit of their religious, political, or other ideals.',
   'Vocabulary', 'FIA Inspector 2022', 'medium', true, 3, 'medium', true),

  ('b2e1000e-eeee-4b4c-c5d6-e7f8a9b0c1d2',
   'Fill in the blank with the appropriate preposition: ''The arrogant man was devoid ________ all common sense.''',
   '["from","with","of","in"]',
   2,
   'The adjective ''devoid'' (meaning entirely lacking or free from) is grammatically always followed by the preposition ''of''.',
   'Prepositions', 'NTS 2023', 'medium', true, 9, 'high', true),

  ('b2e1000f-ffff-4c5d-d6e7-f8a9b0c1d2e3',
   'Which one word successfully substitutes the phrase: ''A person who hates mankind''?',
   '["Philanthropist","Misogynist","Misanthrope","Optimist"]',
   2,
   'A ''Misanthrope'' is someone who despises human society and hates mankind. A ''Philanthropist'' loves mankind, while a ''Misogynist'' specifically hates women.',
   'One Word Substitution', 'FPSC Inspector 2024', 'high', true, 6, 'high', true)

