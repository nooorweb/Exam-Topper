-- ─────────────────────────────────────────────────────────────
-- 2. Pakistan Studies MCQs  →  pakistan_studies_mcqs
-- ─────────────────────────────────────────────────────────────
INSERT INTO public.pakistan_studies_mcqs (id, question, options, correct_answer, explanation, subcategory, exam_type, difficulty, is_repeated, repeat_count, importance, is_public)
VALUES
  ('b3p30001-1111-4a1b-82c3-d4e5f6a7b8c9',
   'In which month and year did the Parliament of Pakistan pass the historic 25th Constitutional Amendment to merge FATA with KPK?',
   '["May 2018","August 2018","January 2019","May 2017"]',
   0,
   'The 25th Constitutional Amendment was passed by the National Assembly on May 24, 2018, and by the Senate on May 25, 2018. It received presidential assent on May 31, 2018.[4]',
   'Governance', 'KPPSC PMS 2022', 'high', true, 7, 'high', true),

  ('b3p30002-2222-4b2c-83d4-e5f6a7b8c9d0',
   'The 25th Constitutional Amendment reduced the total membership of the National Assembly of Pakistan from 342 to:',
   '["342 seats","336 seats","300 seats","320 seats"]',
   1,
   'The 25th Amendment reduced the National Assembly''s total seats from 342 to 336 by removing the separate tribal area seats and integrating them into KP''s provincial quotas.[4]',
   'Constitution', 'CSS Pakistan Affairs 2023', 'high', true, 5, 'high', true),

  ('b3p30003-3333-4c3d-84e5-f6a7b8c9d0e1',
   'Who was officially appointed as the first Governor General of Pakistan upon independence in 1947?',
   '["Liaquat Ali Khan","Quaid-e-Azam Muhammad Ali Jinnah","Khawaja Nazimuddin","Chaudhry Muhammad Ali"]',
   1,
   'Quaid-e-Azam Muhammad Ali Jinnah served as Pakistan''s first Governor General from August 14, 1947, until his death on September 11, 1948. Liaquat Ali Khan was the first Prime Minister.',
   'Early History', 'FIA Sub-Inspector 2023', 'medium', true, 9, 'high', true),

  ('b3p30004-4444-4d4e-85f6-a7b8c9d0e1f2',
   'Following the historical restructuring of administrative boundaries, the province of Khyber Pakhtunkhwa (KPK) is divided into how many districts?',
   '["34 districts","36 districts","38 districts","40 districts"]',
   3,
   'As of the latest administrative updates, the province of Khyber Pakhtunkhwa officially comprises exactly 40 districts.',
   'Geography', 'ETEA Computer Operator 2024', 'high', true, 8, 'high', true),

  ('b3p30005-5555-4e5f-86a7-b8c9d0e1f2a3',
   'Administratively, the 40 districts of Khyber Pakhtunkhwa are grouped into how many overarching Divisions?',
   '["5 divisions","6 divisions","7 divisions","8 divisions"]',
   2,
   'Khyber Pakhtunkhwa consists of exactly 7 administrative divisions: Peshawar, Mardan, Hazara, Malakand, Dera Ismail Khan, Kohat, and Bannu.',
   'Geography', 'KPPSC Assistant Sub-Inspector 2022', 'medium', true, 6, 'high', true),

  ('b3p30006-6666-4f6a-87b8-c9d0e1f2a3b4',
   'Who is the current Chief Justice of the Peshawar High Court?',
   '',
   0,
   'S.M. Attique Shah is the current Chief Justice of the Peshawar High Court, serving as the head of the provincial judiciary.',
   'Governance', 'KPPSC Tehsildar 2025', 'high', false, 0, 'medium', true),

  ('b3p30007-7777-4a7b-88c9-d0e1f2a3b4c5',
   'Under the 7th National Finance Commission (NFC) Award, what is the allocated resource share of the divisible pool for Punjab?',
   '["51.74%","24.55%","14.62%","9.09%"]',
   0,
   'The horizontal distribution of the 7th NFC Award allocated 51.74% of the divisible pool to Punjab, 24.55% to Sindh, 14.62% to KPK, and 9.09% to Balochistan.[5]',
   'Governance', 'CSS Pakistan Affairs 2021', 'high', true, 8, 'high', true),

  ('b3p30008-8888-4b8c-89d0-e1f2a3b4c5d6',
   'In the multi-criteria formula of the 7th NFC Award, what specific percentage weightage is assigned to ''Inverse Population Density''?',
   '["82.0%","10.3%","5.0%","2.7%"]',
   3,
   'To compensate for logistical and administrative costs in vast, sparse territories like Balochistan, a weightage of 2.7% was assigned to Inverse Population Density.[5]',
   'Governance', 'KPPSC PMS 2022', 'high', true, 4, 'high', true),

  ('b3p30009-9999-4c9d-8012-f2a3b4c5d6e7',
   'The Sabakzai Dam, which ranks as the seventh-largest in the world by floodstock capacity, is constructed on which river in Balochistan?',
   '',
   1,
   'The Sabakzai Dam is an embankment dam constructed on the Zhob River in Balochistan. Construction on the project began in 2004.[6]',
   'Geography', 'FPSC Inspector 2024', 'high', true, 3, 'medium', true),

  ('b3p30010-aaaa-4d0e-81f2-a3b4c5d6e7f8',
   'What is the total hydropower installation capacity of the Warsak Dam located on the Kabul River in KPK?',
   '',
   1,
   'The Warsak Dam, completed in two phases (1960 and 1980-81), has a total hydropower electricity generation capacity of 243 MW.[6]',
   'Geography', 'ETEA SST General 2024', 'high', true, 5, 'medium', true)

